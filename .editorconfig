root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,yml,yaml,html,css,scss,md}]
indent_size = 2

[*.py]
indent_size = 4
max_line_length = 100

[Makefile]
indent_style = tab

[*.{md,markdown}]
trim_trailing_whitespace = false
