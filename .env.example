# Copy this file to `.env` and replace each `CHANGEME_*` placeholder with a
# strong random value (e.g. `openssl rand -hex 32`). `.env` is gitignored;
# never commit it.
#
# Each CHANGEME_* token belongs to a single credential. POSTGRES_PASSWORD
# and DATABASE_URL share `CHANGEME_PG` because they must match; MinIO uses
# its own `CHANGEME_MINIO`. The README's bootstrap block fills both with
# distinct random values in one shot.

# --- Postgres (T1.1) --------------------------------------------------------
POSTGRES_USER=vargate
POSTGRES_PASSWORD=CHANGEME_PG
POSTGRES_DB=vargate_telemetry

# Application connection string. Used by the Telemetry gateway (lands in
# T1.4) and by Alembic for migrations. Driver is psycopg 3
# (`postgresql+psycopg://`); plain `postgresql://` also works for the psql
# client. Host `postgres` resolves on the default compose network.
DATABASE_URL=postgresql+psycopg://vargate:CHANGEME_PG@postgres:5432/vargate_telemetry

# --- MinIO (T1.2 + T5.0) ----------------------------------------------------
# S3-compatible object store for tenant content blobs. Every blob is
# AES-GCM-encrypted with the tenant's DEK BEFORE it reaches MinIO
# (T5.1 lands the encrypt path) — MinIO never sees plaintext, so we do
# NOT enable MinIO server-side encryption. Two layers of crypto would
# only obscure the audit story without adding strength.
MINIO_ROOT_USER=vargate-admin
MINIO_ROOT_PASSWORD=CHANGEME_MINIO

# Where MinIO redirects after a console login. In dev there's no host port
# mapping (console is internal-only on `expose`); in T1.9 prod overlay,
# nginx will reverse-proxy this URL to the console on 9001. Leaving it as
# localhost is fine for the local-only dev case.
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# T5.0: S3 endpoint URL used by `vargate_telemetry.storage.object_store`.
# The Python boto3 client points at this; in compose it resolves via the
# `minio` service name on the internal network. Override per environment
# (staging/prod can point at a different MinIO cluster or AWS S3 entirely
# — the wrapper is endpoint-agnostic).
MINIO_ENDPOINT=http://minio:9000

# T5.0: Single bucket holding all tenant content blobs, keyed by
# `tenants/{tenant_id}/...`. The `minio-bootstrap` compose service
# creates it on first `up`; the wrapper refuses to write if it's
# missing. Kept in env so a future migration can swap names without a
# code change.
MINIO_TENANT_CONTENT_BUCKET=tenant-content

# T6.0: scoped MinIO service account credentials. When set, the gateway
# + worker use these (least-privilege: Put/Get/Delete on
# tenant-content/* only) instead of the root creds above, and the
# minio-bootstrap service creates the account with that scoped policy.
# Leave UNSET to fall back to root creds (dev / pre-migration). Generate
# distinct random values; never reuse the root password.
OGMA_MINIO_ACCESS_KEY=
OGMA_MINIO_SECRET_KEY=

# --- Celery / Redis (T1.3, T2.3) --------------------------------------------
# Redis is the broker and result backend for Celery, and (from T2.3) the
# host of per-tenant metering counters. DB 0 holds the metering hash;
# DB 1 holds the Celery task queue; DB 2 holds task results. Dev Redis
# runs without auth on the internal compose network; T1.9 prod overlay
# adds AUTH and TLS.
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- HSM (T1.6) -------------------------------------------------------------
# SoftHSM2 is installed in the Telemetry image. Tokens live in the
# `vargate-hsm-tokens` named volume so the KEK survives container
# restarts. The Telemetry KEK wraps every per-tenant DEK; losing it
# crypto-shreds every encrypted blob.

# Path to the PKCS#11 module inside the container. SoftHSM2's Debian
# package ships the .so at this path; override only if you've installed
# a different PKCS#11 provider.
PKCS11_MODULE=/usr/lib/softhsm/libsofthsm2.so

# Stable labels used to look up the token and the KEK in the HSM.
HSM_TOKEN_LABEL=vargate-telemetry
HSM_KEK_LABEL=telemetry-kek-v1

# PINs for the SoftHSM2 token. SO_PIN authorizes administrative ops
# (token init, KEK creation); HSM_PIN authorizes ordinary use
# (wrap/unwrap). Both must be 4-32 chars in PKCS#11 spec, but SoftHSM2
# tolerates longer strings — the bootstrap script generates 64-char
# hex values, well within tolerance.
HSM_SO_PIN=CHANGEME_HSM_SO
HSM_PIN=CHANGEME_HSM_USER

# --- Stripe (T2.4) ----------------------------------------------------------
# Test-mode key only this sprint. The metering flush calls
# `SubscriptionItem.create_usage_record` for each (tenant, bucket,
# record_type) entry; failures fall back to the `billing_retry` table.
# Production live-mode wiring lands in a later sprint with explicit
# tenant_billing onboarding via the dashboard.
STRIPE_API_KEY_TEST=sk_test_CHANGEME_STRIPE

# --- Region (T3.5) ----------------------------------------------------------
# The Celery beat scheduler filters the `tenants` index by this region
# so each regional deployment only pulls its own tenants. Defaults to
# `us` if unset. Add `eu`, `apac`, etc. as new deployments come online.
VARGATE_REGION=us

# --- Anthropic Admin API (T3.7 smoke) ---------------------------------------
# Test-org admin key used by `scripts/smoke_t3_real_pull.py` and (later)
# T4 onboarding's read-only key-validation call. Real onboarded tenants
# seal their own per-tenant key into `encrypted_secrets`; this env var
# is only the credential for the smoke-test tenant. Leave empty in
# normal dev — the smoke script refuses to run without it.
ANTHROPIC_ADMIN_KEY_TEST=

# --- SSO + JWT (T4.2) -------------------------------------------------------
# Google and Microsoft OAuth client credentials. Issued from each
# provider's console; the same client ids ship in `vargate-frontend/
# apps/ogma-dashboard/` for the auth-URL construction. Secrets stay
# server-side only.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Where the provider redirects the browser after sign-in. The
# frontend page at this URL POSTs the {code, state} back to the
# gateway's `/api/auth/sso/{provider}/callback`. No trailing slash.
# Local dev typically points at the Vite server on :5173.
OGMA_OAUTH_REDIRECT_BASE=https://vargate.ai

# 256-bit signing key for the session JWT. Generate once per env
# with `openssl rand -hex 32`. Rotation is a future concern; for now
# keep the key the same across worker + gateway restarts so live
# sessions don't break.
JWT_SIGNING_KEY=CHANGEME_JWT_SIGNING_KEY

# --- TM2 bridge JWT keypair (Phase A2) -------------------------------------
# ECDSA P-256 keypair used to sign the short-lived (60s) JWTs that bridge
# Ogma's gateway to the MCP server during the SSO flow. Generate once per
# env with:
#
#   python scripts/generate_bridge_jwt_keypair.py \
#       --out ops/dev-secrets/bridge_jwt_private.pem
#
# (dev — that path is gitignored and bind-mounted in docker-compose.yml.
#  For prod, generate into /home/vargate/secrets/ and set the HOST_PATH
#  env var below so the compose mount picks up the right file.)
#
# OGMA_BRIDGE_JWT_PRIVATE_KEY_HOST_PATH points to the host-side file
# the docker-compose service bind-mounts. The container always sees the
# file at /run/secrets/bridge_jwt_private.pem regardless.
OGMA_BRIDGE_JWT_PRIVATE_KEY_HOST_PATH=./ops/dev-secrets/bridge_jwt_private.pem

# Key id surfaced in the JWK + JWT header. Bump this when rotating so
# the MCP server's cached public key can be distinguished from the new
# one. The generation script prints a suggested kid you can paste here.
OGMA_BRIDGE_JWT_KID=ogma-bridge-v1

# CORS origins the gateway accepts credentialed requests from. Comma-
# separated. In production the dashboard is same-origin (served from
# vargate.ai/dashboard/) so CORS is unused; locally the Vite dev
# server on :5173 needs to be allowed.
OGMA_CORS_ORIGINS=http://localhost:5173

# --- TM3 budget-alert email (AWS SES, Phase B4) ----------------------------
# Consumed by the celery-worker (the evaluate_budgets task sends alert
# email via notify.send_email). Full setup — verified sender identity,
# IAM policy, sandbox status — in docs/ops/integrations/aws-ses.md.
#
# OGMA_ALERT_FROM_ADDRESS: the verified SES sender. UNSET (blank) is a
# valid state: budget alerts still record + show in /alerts, but no
# email is sent (the module raises SesNotConfigured, the evaluator
# catches + logs). Set it to switch the email path on.
OGMA_ALERT_FROM_ADDRESS=
# SES is regional; the sender identity must be verified in this region.
AWS_SES_REGION=eu-west-1
# boto3 reads these from its default credential chain. SECRETS — real
# values go in .env on the box ONLY, never committed.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# The "View & acknowledge in dashboard" CTA link in the alert email.
OGMA_DASHBOARD_URL=https://ogma.vargate.ai
