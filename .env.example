# Copy this file to `.env` and fill in real values. `.env` is gitignored;
# never commit it. Generate strong random values with:
#
#   POSTGRES_PASSWORD=$(openssl rand -hex 32)
#
# After editing the password here, also update DATABASE_URL below to use the
# same value (or, if your loader supports it, switch DATABASE_URL to the
# interpolated form noted in the comment).

# --- Postgres (T1.1) --------------------------------------------------------
POSTGRES_USER=vargate
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vargate_telemetry

# Application connection string. Used by the Telemetry gateway (lands in
# T1.4) and by Alembic for migrations. Driver is psycopg 3
# (`postgresql+psycopg://`); plain `postgresql://` also works for the psql
# client. Host `postgres` resolves on the default compose network.
#
# If you prefer not to duplicate the password, docker-compose interpolates
# values from this file at startup, so you can use:
#   DATABASE_URL=postgresql+psycopg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# Tools that read .env without compose-style interpolation (some
# python-dotenv setups, for example) will not expand the placeholders, so
# the literal form below is the safer default.
DATABASE_URL=postgresql+psycopg://vargate:changeme@postgres:5432/vargate_telemetry
